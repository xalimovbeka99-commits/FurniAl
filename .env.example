# FurniAI Environment Variables
# Copy this file to .env.local and fill in real values before running locally.
# On Vercel: add these in the Project → Settings → Environment Variables panel.

# ── AI Sales Agent ──────────────────────────────────────────────────────────
# Required for /api/sales-agent. Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── WhatsApp Cloud API (optional) ───────────────────────────────────────────
# Required only if you enable /api/whatsapp webhook integration.
# Provision credentials at https://developers.facebook.com/apps
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
